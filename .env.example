# Copy to .env (local dev) or /opt/seowebsitesbuilder/.env (prod, mode 600)
# and fill values. Every key below is required unless marked optional.

# === Postgres ===
POSTGRES_PASSWORD=seo_dev_password
DATABASE_URL=postgres://seo:seo_dev_password@127.0.0.1:5432/seobuilder

# === Auth ===
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-prod-please

# === Encryption-at-rest for BYOK API keys ===
# Generate: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=change-me-in-prod-please

# === Trial AI pool (optional — empty disables the pool entirely) ===
TRIAL_ANTHROPIC_API_KEY=

# === Admin promotion (optional) ===
# Email that auto-gets is_admin=true on next signup/login. Set to your own.
ADMIN_EMAIL=

# === Email delivery (optional — falls back to logging to pm2 if unset) ===
RESEND_API_KEY=
EMAIL_FROM=Seowebsitesbuilder <noreply@seowebsitesbuilder.com>

# === Sentry error tracking (optional — disabled if unset) ===
# Orchestrator + Next server runtime use SENTRY_DSN.
# Client bundles use NEXT_PUBLIC_SENTRY_DSN (must be set at build time).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional: source-map upload during `next build`
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === Public URLs (used by the web build) ===
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000

# === Non-secret runtime config ===
PORT=4000
PROJECT_VOLUMES_DIR=/var/seobuilder/projects
TEMPLATES_DIR=/opt/seowebsitesbuilder/packages/templates
